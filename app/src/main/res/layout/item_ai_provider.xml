<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@color/color_bg_elevated"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row: drag handle | provider name | enabled switch | remove -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_drag_handle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="Drag to reorder"
                android:padding="4dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_provider_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/color_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/color_accent_green"
                android:trackTint="@color/color_border" />

            <ImageButton
                android:id="@+id/btn_remove"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remove provider"
                android:layout_marginStart="4dp"
                android:tint="@color/color_text_secondary" />

        </LinearLayout>

        <!-- API Key field (used by both provider types) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Key"
            style="@style/Style.Macro.InputField"
            app:passwordToggleEnabled="true"
            android:layout_marginTop="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/color_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Model selection label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="2dp" />

        <!-- Model dropdown -->
        <Spinner
            android:id="@+id/spinner_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/color_bg_surface"
            android:popupBackground="@color/color_bg_elevated"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <!-- Test button row with loading spinner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_test"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test Key"
                style="@style/Style.Macro.Button.Primary" />

            <ProgressBar
                android:id="@+id/progress_testing"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/color_accent_green"
                android:layout_marginStart="12dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>


