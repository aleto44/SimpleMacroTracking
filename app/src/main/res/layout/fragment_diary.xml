<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date navigation row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btn_prev_day"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#8249;"
                    android:textSize="24sp"
                    android:textColor="@color/color_text_secondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous day" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground" />

                <TextView
                    android:id="@+id/btn_next_day"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="&#8250;"
                    android:textSize="24sp"
                    android:textColor="@color/color_text_secondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next day" />

            </LinearLayout>

            <!-- Hero Calorie Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/color_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALORIES"
                        android:textAppearance="@style/TextAppearance.Macro.SectionLabel" />

                    <TextView
                        android:id="@+id/tv_calories_hero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.Macro.HeroNumber"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_calories_remaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— remaining"
                            android:textColor="@color/color_accent_green"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_calories_goal_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" / GOAL"
                            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
                            android:textAllCaps="false"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <com.example.simplemacrotracking.ui.shared.MacroProgressView
                        android:id="@+id/progress_calories"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tv_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Macros Card — stacked protein / carbs / fat -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_macros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_bg_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Protein row -->
                    <LinearLayout
                        android:id="@+id/row_protein"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PROTEIN"
                            android:textAppearance="@style/TextAppearance.Macro.SectionLabel" />
                        <TextView
                            android:id="@+id/tv_protein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <com.example.simplemacrotracking.ui.shared.MacroProgressView
                        android:id="@+id/progress_protein"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Carbs row -->
                    <LinearLayout
                        android:id="@+id/row_carbs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CARBS"
                            android:textAppearance="@style/TextAppearance.Macro.SectionLabel" />
                        <TextView
                            android:id="@+id/tv_carbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <com.example.simplemacrotracking.ui.shared.MacroProgressView
                        android:id="@+id/progress_carbs"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Fat row -->
                    <LinearLayout
                        android:id="@+id/row_fat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="FAT"
                            android:textAppearance="@style/TextAppearance.Macro.SectionLabel" />
                        <TextView
                            android:id="@+id/tv_fat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <com.example.simplemacrotracking.ui.shared.MacroProgressView
                        android:id="@+id/progress_fat"
                        android:layout_width="match_parent"
                        android:layout_height="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Entries section header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TODAY'S ENTRIES"
                android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

