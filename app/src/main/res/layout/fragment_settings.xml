<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DAILY GOALS"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:layout_marginBottom="12dp" />

        <!-- Calories -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Calories"
            style="@style/Style.Macro.InputField"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_calories"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/color_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Protein + Carbs row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Protein (g)"
                style="@style/Style.Macro.InputField"
                android:layout_marginEnd="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_protein"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/color_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Carbs (g)"
                style="@style/Style.Macro.InputField"
                android:layout_marginStart="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_carbs"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/color_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Fat -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Fat (g)"
            style="@style/Style.Macro.InputField"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_fat"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/color_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button android:id="@+id/btn_save_goals"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Save Goals"
            style="@style/Style.Macro.Button.Primary"
            android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/color_border" android:layout_marginBottom="16dp" />

        <!-- Weight unit -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEIGHT UNIT"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:layout_marginBottom="12dp" />

        <RadioGroup android:id="@+id/rg_weight_unit"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rb_lb" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="lb"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_accent_green"
                android:checked="true" />
            <RadioButton android:id="@+id/rb_kg" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="kg"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_accent_green"
                android:layout_marginStart="16dp" />
        </RadioGroup>

        <ProgressBar android:id="@+id/progress_converting"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:indeterminateTint="@color/color_accent_green"
            android:visibility="gone" android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/color_border" android:layout_marginBottom="16dp" />

        <!-- AI Configuration -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AI CONFIGURATION"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Providers are tried top-to-bottom. Drag to reorder."
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ai_providers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="8dp" />

        <!-- Add provider buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button android:id="@+id/btn_add_gemini"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ Gemini"
                style="@style/Style.Macro.Button.Ghost"
                android:layout_marginEnd="4dp" />

            <Button android:id="@+id/btn_add_github_models"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ GitHub Models"
                style="@style/Style.Macro.Button.Ghost"
                android:layout_marginStart="4dp" />

        </LinearLayout>


        <!-- Hidden legacy views kept to avoid binding crashes -->
        <View android:id="@+id/et_api_key" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <Button android:id="@+id/btn_test_api_key"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:visibility="gone" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/color_border" android:layout_marginBottom="16dp" />

        <!-- Data / CSV -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DATA"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btn_export_diary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Export Diary CSV"
            style="@style/Style.Macro.Button.Ghost"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_export_weight"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Export Weight CSV"
            style="@style/Style.Macro.Button.Ghost"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_import_csv"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Import CSV"
            style="@style/Style.Macro.Button.Ghost"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

