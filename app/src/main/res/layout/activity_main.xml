<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary">

    <!-- Dark top spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_bg_primary"
        android:elevation="0dp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_marginBottom="80dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- 1dp top border above bottom nav -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="80dp"
        android:background="@color/color_border" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/color_bg_surface"
        app:itemIconTint="@color/bottom_nav_item"
        app:itemTextColor="@color/bottom_nav_item"
        app:itemActiveIndicatorStyle="@android:style/Widget.Holo"
        app:layout_insetEdge="bottom"
        app:menu="@menu/menu_bottom_nav" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Add"
        app:backgroundTint="@color/color_accent_green"
        app:elevation="4dp"
        app:layout_dodgeInsetEdges="bottom"
        app:tint="@color/color_bg_primary"
        app:srcCompat="@drawable/ic_add" />

    <!-- Mic FAB: 32dp custom size, vertically centred with the 56dp plus FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_mic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="88dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Voice entry"
        android:visibility="gone"
        app:backgroundTint="@color/color_accent_green"
        app:elevation="4dp"
        app:fabCustomSize="32dp"
        app:fabSize="mini"
        app:iconSize="12dp"
        app:layout_dodgeInsetEdges="bottom"
        app:tint="@color/color_bg_primary"
        app:srcCompat="@drawable/ic_mic" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
