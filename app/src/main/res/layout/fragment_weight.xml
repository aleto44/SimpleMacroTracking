<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/color_bg_primary">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WEIGHT LOG"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:textSize="14sp" />
        <ImageButton
            android:id="@+id/btn_chart_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Chart settings" />
        <Button
            android:id="@+id/btn_add_weight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Log Weight"
            style="@style/Style.Macro.Button.Primary" />
    </LinearLayout>

    <!-- Time range chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip android:id="@+id/chip_1w"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1W" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_1m"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1M" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_3m"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3M" android:checked="true" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_1y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1Y" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_3y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3Y" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_5y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5Y" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_all"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="All" style="@style/Style.Macro.Chip" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Display filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip android:id="@+id/chip_show_weight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Weight" android:checked="true"
                style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_show_calories"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Calories" android:checked="true"
                style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_show_moving_avg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Moving Avg"
                style="@style/Style.Macro.Chip" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Line chart with drag-selection overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="4dp">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/line_chart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.example.simplemacrotracking.ui.weight.ChartSelectionOverlay
            android:id="@+id/chart_selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

    </FrameLayout>

    <!-- Chart settings panel (collapsible) -->
    <LinearLayout
        android:id="@+id/layout_chart_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/color_bg_secondary"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Moving Average Window"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/tv_ma_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 days"
                android:textColor="@color/color_text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_ma_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="2"
            android:valueTo="30"
            android:stepSize="1"
            android:value="7" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/color_border" android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_latest_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="4dp"
        android:text="Latest: —" />

    <TextView
        android:id="@+id/tv_weight_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="12dp"
        android:text="Change: —" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/color_border" android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ALL ENTRIES"
        android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
        android:layout_marginBottom="4dp" />

    <!-- Scrollable entries list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_weight_entries"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>

</androidx.core.widget.NestedScrollView>

