<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header row: title + Add button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weight Log"
            android:textStyle="bold"
            android:textSize="18sp" />
        <Button
            android:id="@+id/btn_add_weight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

    <!-- Time range chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_1w"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1W"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_1m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1M"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_3m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3M"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_1y"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1Y"
                style="@style/Widget.MaterialComponents.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                style="@style/Widget.MaterialComponents.Chip.Filter" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Line chart -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/line_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp" />

    <!-- Stats -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="?attr/dividerHorizontal" android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_latest_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:layout_marginBottom="4dp"
        android:text="Latest: —" />

    <TextView
        android:id="@+id/tv_weight_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:text="Change: —" />

</LinearLayout>
