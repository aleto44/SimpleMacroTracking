<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/color_bg_primary">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WEIGHT LOG"
            android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
            android:textSize="14sp" />
        <Button
            android:id="@+id/btn_add_weight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Log Weight"
            style="@style/Style.Macro.Button.Primary" />
    </LinearLayout>

    <!-- Time range chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip android:id="@+id/chip_1w"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1W" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_1m"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1M" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_3m"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3M" android:checked="true" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_1y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1Y" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_3y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="3Y" style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_5y"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5Y" style="@style/Style.Macro.Chip" />
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="All" style="@style/Style.Macro.Chip" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Display filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip android:id="@+id/chip_show_weight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Weight" android:checked="true"
                style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_show_calories"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Calories" android:checked="true"
                style="@style/Style.Macro.Chip" />
            <com.google.android.material.chip.Chip android:id="@+id/chip_show_moving_avg"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Moving Avg"
                style="@style/Style.Macro.Chip" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Line chart -->
    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/line_chart"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="8dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/color_border" android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_latest_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="4dp"
        android:text="Latest: —" />

    <TextView
        android:id="@+id/tv_weight_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="12dp"
        android:text="Change: —" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/color_border" android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ALL ENTRIES"
        android:textAppearance="@style/TextAppearance.Macro.SectionLabel"
        android:layout_marginBottom="4dp" />

    <!-- Scrollable entries list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_weight_entries"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:nestedScrollingEnabled="true"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>
