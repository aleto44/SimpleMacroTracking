<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SimpleMacroTracking" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/color_accent_green</item>
        <item name="colorPrimaryVariant">@color/color_accent_green</item>
        <item name="colorOnPrimary">@color/color_bg_primary</item>
        <item name="colorSecondary">@color/color_accent_green</item>
        <item name="colorSecondaryVariant">@color/color_accent_green</item>
        <item name="colorOnSecondary">@color/color_bg_primary</item>

        <!-- Surfaces -->
        <item name="colorSurface">@color/color_bg_surface</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="android:colorBackground">@color/color_bg_primary</item>
        <item name="android:windowBackground">@color/color_bg_primary</item>

        <!-- Status / nav bars -->
        <item name="android:statusBarColor">@color/color_bg_primary</item>
        <item name="android:navigationBarColor">@color/color_bg_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/color_text_primary</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>

        <!-- Default card style: zero elevation, border stroke -->
        <item name="materialCardViewStyle">@style/Style.Macro.Card</item>

        <!-- Bottom sheet -->
        <item name="bottomSheetDialogTheme">@style/Theme.Macro.BottomSheet</item>

        <!-- Alert dialogs -->
        <item name="materialAlertDialogTheme">@style/Theme.Macro.AlertDialog</item>

        <!-- Chip -->
        <item name="chipStyle">@style/Style.Macro.Chip</item>
    </style>

    <!-- ── Macro Card ── -->
    <style name="Style.Macro.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/color_bg_surface</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/color_border</item>
    </style>

    <!-- ── Primary Button (green fill) ── -->
    <style name="Style.Macro.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/color_accent_green</item>
        <item name="android:textColor">@color/color_bg_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ── Ghost Button (border, no fill) ── -->
    <style name="Style.Macro.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/color_border</item>
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ── Chip ── -->
    <style name="Style.Macro.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/color_bg_elevated</item>
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="chipStrokeColor">@color/color_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- ── Alert Dialog ── -->
    <style name="Theme.Macro.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/color_bg_surface</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="android:textColorPrimary">@color/color_text_primary</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Style.Macro.Button.Primary</item>
    </style>

    <!-- ── Bottom Sheet theme ── -->
    <style name="Theme.Macro.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Style.Macro.BottomSheet</item>
    </style>
    <style name="Style.Macro.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@color/color_bg_surface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Macro.BottomSheet</item>
    </style>
    <style name="ShapeAppearance.Macro.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ── Input field ── -->
    <style name="Style.Macro.InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxBackgroundColor">@color/color_bg_elevated</item>
        <item name="boxStrokeColor">@color/color_border</item>
        <item name="hintTextColor">@color/color_text_secondary</item>
        <item name="android:textColorHint">@color/color_text_secondary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <!-- ── Text appearances ── -->
    <style name="TextAppearance.Macro.HeroNumber" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">48sp</item>
    </style>
    <style name="TextAppearance.Macro.SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="TextAppearance.Macro.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/color_text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextAppearance.Macro.Accent" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/color_accent_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>