<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+: exclude sensitive shared preferences from cloud backup and device transfer -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="settings.xml"/>
    </device-transfer>
</data-extraction-rules>